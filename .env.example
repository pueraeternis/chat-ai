# cp .env.example .env  &&  edit HF_CACHE_ROOT, HF_HUB_CACHE, SEARXNG_SECRET
#
# Full stack: docker compose up -d --build
# Host ports and model ids are set here. In-container service URLs (vllm,
# web-search-mcp) are wired in docker-compose.yml unless overridden below.

# --- Hugging Face (set paths for your machine) ---
HF_CACHE_ROOT=/path/to/.cache/huggingface
HF_HUB_CACHE=/path/to/.cache/huggingface/hub

# --- Host ports ---
# Public: chat-proxy and Open WebUI bind on all interfaces.
CHAT_PROXY_PORT=18080
OPEN_WEBUI_PORT=13000
# Internal (debug): vLLM, SearXNG, web-search MCP bind to 127.0.0.1 only in Compose.
VLLM_PORT=19000
SEARXNG_PORT=18081
WEB_SEARCH_MCP_PORT=13333

# --- vLLM model (Compose passes these to vLLM and chat-proxy) ---
VLLM_IMAGE_TAG=v0.12.0
VLLM_HF_MODEL=Qwen/Qwen3-VL-30B-A3B-Instruct
VLLM_SERVED_MODEL=qwen3-vl-30b-instruct
# CHAT_PROXY_DEFAULT_MODEL is set from VLLM_SERVED_MODEL in docker-compose.yml

# --- chat-proxy (in-container URLs; override only if you change Compose networking) ---
# CHAT_PROXY_WEB_SEARCH_MCP_URL=http://web-search-mcp:3333/mcp

# --- web-search MCP container ---
SEARXNG_SECRET=dev-only-change-me-or-set-in-.env
WEB_SEARCH_SEARXNG_BASE_URL=http://searxng:8080

# --- chat-proxy logging (optional) ---
# CHAT_PROXY_LOG_LEVEL=INFO
# CHAT_PROXY_LOG_JSON=false

# --- Open WebUI ---
OPENAI_API_KEY=dummy
RAG_EMBEDDING_MODEL=BAAI/bge-m3
